						"width": 40,
						"height": 40,
						"content": "var w = rect.getWidth(),\n    h = w / 2,\n    m = w / 8;\ncanvas.fillEllipse(rect.x1 + m, rect.y1 + m, rect.x2 - m, rect.y2 - m);\ncanvas.ellipse(rect.x1 + m, rect.y1 + m, rect.x2 - m, rect.y2 - m);\ncanvas.line(rect.x1 + h, rect.y1 + m, rect.x1 + h + m, rect.y1);\ncanvas.line(rect.x1 + h, rect.y1 + m, rect.x1 + h + m, rect.y1 + 2 * m);\n",
						"smallIcon": "<svg version=\"1.1\" id=\"Layer_1\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" x=\"0px\" y=\"0px\"\n\t width=\"16px\" height=\"16px\" viewBox=\"0 0 16 16\" enable-background=\"new 0 0 16 16\" xml:space=\"preserve\">\n<circle fill=\"none\" stroke=\"#AC9531\" stroke-miterlimit=\"10\" cx=\"8.5\" cy=\"8.5\" r=\"4\"/>\n<line fill=\"none\" stroke=\"#AC9531\" stroke-miterlimit=\"10\" x1=\"8.5\" y1=\"4.5\" x2=\"10\" y2=\"7\"/>\n<line fill=\"none\" stroke=\"#AC9531\" stroke-miterlimit=\"10\" x1=\"8.5\" y1=\"4.5\" x2=\"10\" y2=\"2\"/>\n</svg>"
